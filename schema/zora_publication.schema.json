{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ZoraPublication",
  "description": "One line of data/publications.jsonl. Mirrors src/output_schema.py — keep both in sync. Field names match ZoraRecord in the main repo.",
  "type": "object",
  "required": ["id"],
  "properties": {
    "id": {
      "type": "string",
      "description": "ZORA handle, stable across harvests"
    },
    "doi": {
      "type": ["string", "null"]
    },
    "title": {
      "type": ["string", "null"]
    },
    "abstract": {
      "type": ["string", "null"]
    },
    "authors": {
      "type": "array",
      "items": { "type": "string" }
    },
    "year": {
      "type": ["integer", "null"]
    },
    "publication_type": {
      "type": ["string", "null"]
    },
    "keywords": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Subject keywords from dc.subject, for topic matching"
    },
    "url": {
      "type": ["string", "null"],
      "description": "Link to the ZORA landing page"
    }
  }
}
